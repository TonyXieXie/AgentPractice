{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-agent-next",
  "version": "0.1.0",
  "identifier": "com.xiejihao.tauri-agent-next",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "tauri-agent-next",
        "width": 1480,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 760,
        "decorations": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
