{
  "name": "tauri-agent-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:backend": "set TAURI_AGENT_DEV=1 && python-backend\\venv\\Scripts\\python -m uvicorn python-backend.main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run tauri dev\"",
    "test:m0": "python-backend\\venv\\Scripts\\python -m pytest tests/m0_schema -q",
    "test:m1": "python-backend\\venv\\Scripts\\python -m pytest tests/m1_db -q",
    "test:m2": "python-backend\\venv\\Scripts\\python -m pytest tests/m2_orchestrator -q",
    "test:m3": "python-backend\\venv\\Scripts\\python -m pytest tests/m3_api_ws -q",
    "test:m4": "npx playwright test tests/e2e/tasks-ui.spec.ts",
    "test:m5": "python-backend\\venv\\Scripts\\python -m pytest tests/m5_compat -q",
    "test:core": "npm run test:m0 && npm run test:m1 && npm run test:m2 && npm run test:m3 && npm run test:m5"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "katex": "^0.16.28",
    "markdown-it": "^14.1.0",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^10.9.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
