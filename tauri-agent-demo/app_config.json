{
  "llm": {
    "timeout_sec": 180.0,
    "reasoning_summary": "concise",
    "auto_title_enabled": false
  },
  "agent": {
    "react_max_iterations": 200,
    "base_system_prompt": "",
    "subagent_profile": "",
    "mcp": {
      "servers": [
        {
          "server_label": "figma_desktop",
          "enabled": true,
          "server_url": "http://127.0.0.1:3845/mcp"
        },
        {
          "server_label": "mcp_demo",
          "enabled": true,
          "server_url": "http://127.0.0.1:8765/mcp",
          "server_description": "本地 MCP 示例（echo / image_demo）",
          "allowed_tools": [
            "echo",
            "image_demo"
          ],
          "require_approval": "never"
        }
      ]
    },
    "abilities": [
      {
        "id": "tools_all",
        "name": "All Tools",
        "type": "tooling",
        "tools": [
          "rg",
          "write_file",
          "list_files",
          "apply_patch",
          "spawn_subagent",
          "run_shell",
          "search",
          "read_file"
        ],
        "prompt": ""
      },
      {
        "id": "rg_search",
        "name": "RG Search",
        "type": "tooling",
        "tools": [
          "rg"
        ],
        "prompt": "Prefer rg for searching file contents."
      },
      {
        "id": "apply_patch",
        "name": "Apply Patch",
        "type": "tooling",
        "tools": [
          "apply_patch"
        ],
        "prompt": "Prefer apply_patch for file modifications; avoid rewriting entire files unless necessary.\napply_patch format (strict):\n  *** Begin Patch\n  *** Update File: path\n  @@\n  - old line\n  + new line\n  *** End Patch\n- Each change line must start with + or -, and context lines must be included under @@ hunks.\n- Do NOT wrap apply_patch content in code fences; send raw patch text only.\n- apply_patch matches by context; if the match is not unique, request more surrounding context.\n- If apply_patch fails due to context, ask for more context and retry."
      },
      {
        "id": "pty_status",
        "name": "Live PTY",
        "type": "workflow",
        "prompt": "Live PTY sessions for this chat:\n{{pty_sessions}}"
      },
      {
        "id": "code_map",
        "name": "Code Map",
        "type": "domain_knowledge",
        "prompt": "{{code_map_prompt}}"
      },
      {
        "id": "tool_json",
        "name": "Tool Arguments JSON",
        "type": "tool_policy",
        "prompt": "If a tool is needed, call it with JSON arguments that match its schema."
      },
      {
        "id": "output_concise",
        "name": "Concise Output",
        "type": "output_format",
        "prompt": "Be concise and actionable."
      },
      {
        "id": "file_references",
        "name": "File References",
        "type": "output_format",
        "prompt": "File References: When referencing files in your response, make sure to include the relevant start line and always follow the below rules:\n- Use inline code to make file paths clickable.\n- Each reference should have a stand alone path. Even if it's the same file.\n- Accepted: absolute, workspace-relative, a/ or b/ diff prefixes, or bare filename/suffix.\n- Line/column (1-based, optional): :line[:column] or #Lline[Ccolumn] (column defaults to 1).\n- Do not use URIs like file://, vscode://, or https://.\n- Do not provide range of lines.\n- Examples: src/app.ts, src/app.ts:42, b/server/index.js#L10, C:\\repo\\project\\main.rs:12:5"
      },
      {
        "id": "websear",
        "name": "WebSear",
        "type": "tooling",
        "prompt": "Prefer web search for more information.",
        "tools": [
          "search"
        ]
      },
      {
        "id": "tool-read-file",
        "name": "Read File",
        "type": "tooling",
        "tools": [
          "read_file"
        ],
        "prompt": ""
      },
      {
        "id": "tool-write-file",
        "name": "Write File",
        "type": "tooling",
        "tools": [
          "write_file"
        ],
        "prompt": ""
      },
      {
        "id": "tool-list-files",
        "name": "List Files",
        "type": "tooling",
        "tools": [
          "list_files"
        ],
        "prompt": ""
      },
      {
        "id": "tool-run-shell",
        "name": "Run Shell",
        "type": "tooling",
        "tools": [
          "run_shell"
        ],
        "prompt": ""
      },
      {
        "id": "tool-code-ast",
        "name": "Code Ast",
        "type": "tooling",
        "tools": [
          "code_ast"
        ],
        "prompt": ""
      },
      {
        "id": "tool-spawn-subagent",
        "name": "Spawn Subagent",
        "type": "tooling",
        "tools": [
          "spawn_subagent"
        ],
        "prompt": ""
      }
    ],
    "profiles": [
      {
        "id": "default",
        "name": "Default",
        "abilities": [
          "rg_search",
          "apply_patch",
          "tool_json",
          "output_concise",
          "tool-read-file",
          "websear",
          "tool-list-files",
          "tool-run-shell",
          "tool-spawn-subagent",
          "file_references",
          "pty_status"
        ],
        "spawnable": false,
        "description": "You are a helpful AI assistant."
      },
      {
        "id": "subagent",
        "name": "Subagent-Search",
        "abilities": [
          "websear",
          "output_concise"
        ],
        "spawnable": true,
        "description": "A subagent can websearch."
      },
      {
        "id": "subagent-find",
        "name": "subagent_Find",
        "description": "A subagent can list/rg/read files",
        "abilities": [
          "file_references",
          "rg_search",
          "tool-read-file",
          "tool-list-files"
        ],
        "spawnable": true
      }
    ],
    "default_profile": "default",
    "ast_enabled": true,
    "code_map": {
      "enabled": true,
      "max_symbols": 40,
      "max_files": 20,
      "max_lines": 30,
      "weight_refs": 1.0,
      "weight_mentions": 2.0
    }
  },
  "context": {
    "compression_enabled": true,
    "compress_start_pct": 75,
    "compress_target_pct": 25,
    "min_keep_messages": 1,
    "keep_recent_calls": 10,
    "step_calls": 5,
    "truncate_long_data": true,
    "long_data_threshold": 1000,
    "long_data_head_chars": 600,
    "long_data_tail_chars": 400
  }
}